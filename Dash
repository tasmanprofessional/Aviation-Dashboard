<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dash</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #0B0F1A;
      color: #E8EDF5;
      font-family: 'Inter', sans-serif;
      height: 100vh;
      display: flex;
      overflow: hidden;
    }

    .sidebar {
      width: 210px;
      min-width: 210px;
      background: #0E1422;
      border-right: 1px solid #1E2740;
      display: flex;
      flex-direction: column;
      height: 100vh;
    }

    .logo {
      padding: 20px 16px;
      border-bottom: 1px solid #1E2740;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .radar { width: 34px; height: 34px; flex-shrink: 0; }
    .radar svg { width: 34px; height: 34px; }

    .radar-sweep {
      transform-origin: 17px 17px;
      animation: sweep 3s linear infinite;
    }

    @keyframes sweep {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }

    .logo-text {
      font-family: 'Rajdhani', sans-serif;
      font-size: 22px;
      font-weight: 700;
      letter-spacing: 2px;
      color: #E8EDF5;
      text-transform: uppercase;
      line-height: 1;
    }

    .logo-text span {
      display: block;
      font-size: 10px;
      font-weight: 400;
      color: #00C2CC;
      letter-spacing: 3px;
    }

    .nav { flex: 1; padding: 16px 0; overflow-y: auto; }
    .nav-section { margin-bottom: 24px; }

    .nav-section-label {
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #3A4560;
      padding: 0 16px;
      margin-bottom: 4px;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 16px;
      font-size: 13px;
      color: #7A8BAA;
      cursor: pointer;
      border-left: 2px solid transparent;
      transition: all 0.15s;
      text-decoration: none;
    }

    .nav-item:hover { color: #E8EDF5; background: #141929; }

    .nav-item.active {
      color: #00C2CC;
      border-left-color: #00C2CC;
      background: #0F1A2E;
    }

    .nav-item i { font-size: 16px; width: 18px; text-align: center; flex-shrink: 0; }

    .nav-badge {
      margin-left: auto;
      background: #F5A623;
      color: #1A0E00;
      font-size: 10px;
      font-weight: 600;
      padding: 1px 6px;
      border-radius: 10px;
    }

    .nav-badge.teal { background: #00C2CC; color: #002E30; }

    .sidebar-footer {
      padding: 14px 16px;
      border-top: 1px solid #1E2740;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .avatar {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: #1A2840;
      border: 1px solid #2A3A5A;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      color: #00C2CC;
      font-weight: 600;
      flex-shrink: 0;
    }

    .user-name { font-size: 12px; font-weight: 500; color: #C0CDE0; }
    .user-role { font-size: 10px; color: #3A4560; }

    .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 24px;
      border-bottom: 1px solid #1E2740;
      background: #0D1120;
      flex-shrink: 0;
    }

    .page-title {
      font-family: 'Rajdhani', sans-serif;
      font-size: 20px;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    .page-title span { color: #00C2CC; }

    .topbar-right { display: flex; align-items: center; gap: 14px; }

    .status-pill {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: #00C2CC;
      background: #00222440;
      border: 1px solid #00C2CC33;
      padding: 4px 12px;
      border-radius: 20px;
    }

    .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #00C2CC;
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.3; }
    }

    .utc-clock {
      font-family: 'Rajdhani', sans-serif;
      font-size: 13px;
      letter-spacing: 1.5px;
      color: #3A4560;
    }

    .content { flex: 1; overflow-y: auto; padding: 20px 24px; }

    .kpi-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 20px;
    }

    .kpi {
      background: #0E1422;
      border: 1px solid #1E2740;
      border-radius: 8px;
      padding: 14px 16px;
      position: relative;
      overflow: hidden;
    }

    .kpi::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: var(--accent, #00C2CC);
    }

    .kpi-label {
      font-size: 10px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #3A4560;
      margin-bottom: 8px;
    }

    .kpi-value {
      font-family: 'Rajdhani', sans-serif;
      font-size: 28px;
      font-weight: 700;
      color: #E8EDF5;
      line-height: 1;
      margin-bottom: 4px;
    }

    .kpi-sub { font-size: 10px; color: #3A4560; }

    .panel-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 12px;
    }

    .panel {
      background: #0E1422;
      border: 1px solid #1E2740;
      border-radius: 8px;
      overflow: hidden;
    }

    .panel-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 11px 16px;
      border-bottom: 1px solid #1E2740;
    }

    .panel-title {
      font-family: 'Rajdhani', sans-serif;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #7A8BAA;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .panel-action { font-size: 11px; color: #00C2CC; cursor: pointer; }
    .panel-body { padding: 14px 16px; }

    .flight-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 0;
      border-bottom: 1px solid #141929;
      font-size: 12px;
    }

    .flight-item:last-child { border-bottom: none; }

    .flight-num {
      font-family: 'Rajdhani', sans-serif;
      font-weight: 700;
      font-size: 13px;
      color: #00C2CC;
      width: 58px;
      flex-shrink: 0;
    }

    .route { flex: 1; color: #C0CDE0; display: flex; align-items: center; gap: 4px; }
    .route i { font-size: 12px; color: #3A4560; }

    .badge {
      font-size: 10px;
      padding: 2px 8px;
      border-radius: 4px;
      font-weight: 500;
      letter-spacing: 0.5px;
    }

    .s-airborne { background: #003320; color: #2EC27E; }
    .s-delayed  { background: #2A1500; color: #F5A623; }
    .s-gate     { background: #001A30; color: #00C2CC; }
    .s-landed   { background: #1A1A1A; color: #7A8BAA; }

    .bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
    .bar-label { font-size: 11px; color: #7A8BAA; width: 36px; flex-shrink: 0; }

    .bar-track {
      flex: 1;
      height: 6px;
      background: #1E2740;
      border-radius: 3px;
      overflow: hidden;
    }

    .bar-fill { height: 100%; border-radius: 3px; background: #00C2CC; }
    .bar-val { font-size: 11px; color: #3A4560; width: 30px; text-align: right; flex-shrink: 0; }

    .panel-full {
      background: #0E1422;
      border: 1px solid #1E2740;
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 12px;
    }

    .panel-placeholder {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      height: 100px;
      color: #2A3A5A;
      font-size: 11px;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .panel-placeholder i { font-size: 22px; }

    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #1E2740; border-radius: 4px; }
  </style>
</head>
<body>

  <aside class="sidebar">
    <div class="logo">
      <div class="radar">
        <svg viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="17" cy="17" r="15" stroke="#1E2740" stroke-width="1"/>
          <circle cx="17" cy="17" r="9"  stroke="#1E2740" stroke-width="0.5"/>
          <circle cx="17" cy="17" r="4"  stroke="#1E2740" stroke-width="0.5"/>
          <circle cx="17" cy="17" r="2"  fill="#00C2CC"/>
          <g class="radar-sweep">
            <line x1="17" y1="17" x2="17" y2="2" stroke="#00C2CC" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="17" y1="17" x2="25" y2="4" stroke="#00C2CC" stroke-width="1" opacity="0.4"/>
            <line x1="17" y1="17" x2="30" y2="11" stroke="#00C2CC" stroke-width="0.5" opacity="0.1"/>
          </g>
          <circle cx="23" cy="10" r="1.5" fill="#F5A623" opacity="0.9"/>
          <circle cx="11" cy="21" r="1"   fill="#00C2CC" opacity="0.7"/>
        </svg>
      </div>
      <div class="logo-text">
        Dash
        <span>Aviation</span>
      </div>
    </div>

    <nav class="nav">
      <div class="nav-section">
        <div class="nav-section-label">Overview</div>
        <a class="nav-item active" href="#">
          <i class="ti ti-layout-dashboard"></i> Dashboard
        </a>
        <a class="nav-item" href="#">
          <i class="ti ti-map-pin"></i> Live Map
          <span class="nav-badge teal">Live</span>
        </a>
      </div>

      <div class="nav-section">
        <div class="nav-section-label">Operations</div>
        <a class="nav-item" href="#">
          <i class="ti ti-plane"></i> Flights
          <span class="nav-badge">12</span>
        </a>
        <a class="nav-item" href="#">
          <i class="ti ti-building"></i> Airports
        </a>
        <a class="nav-item" href="#">
          <i class="ti ti-clock"></i> Delays
          <span class="nav-badge">3</span>
        </a>
        <a class="nav-item" href="#">
          <i class="ti ti-route"></i> Routes
        </a>
      </div>

      <div class="nav-section">
        <div class="nav-section-label">Analytics</div>
        <a class="nav-item" href="#">
          <i class="ti ti-chart-bar"></i> Performance
        </a>
        <a class="nav-item" href="#">
          <i class="ti ti-users"></i> Passenger Load
        </a>
        <a class="nav-item" href="#">
          <i class="ti ti-coin"></i> Revenue
        </a>
      </div>

      <div class="nav-section">
        <div class="nav-section-label">Fleet</div>
        <a class="nav-item" href="#">
          <i class="ti ti-tools"></i> Maintenance
        </a>
        <a class="nav-item" href="#">
          <i class="ti ti-certificate"></i> Aircraft
        </a>
      </div>
    </nav>

    <div class="sidebar-footer">
      <div class="avatar">AV</div>
      <div>
        <div class="user-name">Ops Control</div>
        <div class="user-role">Administrator</div>
      </div>
      <i class="ti ti-settings" style="margin-left:auto;font-size:15px;color:#3A4560;cursor:pointer"></i>
    </div>
  </aside>

  <main class="main">
    <div class="topbar">
      <div class="page-title">Operations <span>Overview</span></div>
      <div class="topbar-right">
        <div class="status-pill">
          <div class="dot"></div>
          Data Live
        </div>
        <div class="utc-clock" id="clock">UTC 00:00:00</div>
      </div>
    </div>

    <div class="content">

      <div class="kpi-row">
        <div class="kpi" style="--accent:#00C2CC">
          <div class="kpi-label">Active Flights</div>
          <div class="kpi-value">—</div>
          <div class="kpi-sub">Worldwide airborne</div>
        </div>
        <div class="kpi" style="--accent:#2EC27E">
          <div class="kpi-label">On Time Rate</div>
          <div class="kpi-value">—</div>
          <div class="kpi-sub">Today's flights</div>
        </div>
        <div class="kpi" style="--accent:#F5A623">
          <div class="kpi-label">Avg Delay</div>
          <div class="kpi-value">—</div>
          <div class="kpi-sub">Minutes</div>
        </div>
        <div class="kpi" style="--accent:#A070E0">
          <div class="kpi-label">Pax Load</div>
          <div class="kpi-value">—</div>
          <div class="kpi-sub">Avg capacity</div>
        </div>
      </div>

      <div class="panel-row">
        <div class="panel">
          <div class="panel-header">
            <div class="panel-title"><i class="ti ti-plane"></i> Live Flights</div>
            <span class="panel-action">View all →</span>
          </div>
          <div class="panel-body">
            <div class="flight-item">
              <div class="flight-num">QF 007</div>
              <div class="route">SYD <i class="ti ti-arrow-narrow-right"></i> LHR</div>
              <span class="badge s-airborne">Airborne</span>
            </div>
            <div class="flight-item">
              <div class="flight-num">VA 831</div>
              <div class="route">MEL <i class="ti ti-arrow-narrow-right"></i> BNE</div>
              <span class="badge s-delayed">Delayed</span>
            </div>
            <div class="flight-item">
              <div class="flight-num">JQ 514</div>
              <div class="route">PER <i class="ti ti-arrow-narrow-right"></i> SYD</div>
              <span class="badge s-gate">At Gate</span>
            </div>
            <div class="flight-item">
              <div class="flight-num">EK 414</div>
              <div class="route">SYD <i class="ti ti-arrow-narrow-right"></i> DXB</div>
              <span class="badge s-airborne">Airborne</span>
            </div>
            <div class="flight-item">
              <div class="flight-num">QF 429</div>
              <div class="route">BNE <i class="ti ti-arrow-narrow-right"></i> MEL</div>
              <span class="badge s-landed">Landed</span>
            </div>
          </div>
        </div>

        <div class="panel">
          <div class="panel-header">
            <div class="panel-title"><i class="ti ti-building"></i> Airport Load</div>
            <span class="panel-action">Details →</span>
          </div>
          <div class="panel-body">
            <div class="bar-row">
              <div class="bar-label">SYD</div>
              <div class="bar-track"><div class="bar-fill" style="width:87%;background:#F5A623"></div></div>
              <div class="bar-val">87%</div>
            </div>
            <div class="bar-row">
              <div class="bar-label">MEL</div>
              <div class="bar-track"><div class="bar-fill" style="width:74%"></div></div>
              <div class="bar-val">74%</div>
            </div>
            <div class="bar-row">
              <div class="bar-label">BNE</div>
              <div class="bar-track"><div class="bar-fill" style="width:61%"></div></div>
              <div class="bar-val">61%</div>
            </div>
            <div class="bar-row">
              <div class="bar-label">PER</div>
              <div class="bar-track"><div class="bar-fill" style="width:45%"></div></div>
              <div class="bar-val">45%</div>
            </div>
            <div class="bar-row">
              <div class="bar-label">ADL</div>
              <div class="bar-track"><div class="bar-fill" style="width:38%"></div></div>
              <div class="bar-val">38%</div>
            </div>
            <div class="bar-row">
              <div class="bar-label">DRW</div>
              <div class="bar-track"><div class="bar-fill" style="width:22%;background:#2EC27E"></div></div>
              <div class="bar-val">22%</div>
            </div>
          </div>
        </div>
      </div>

      <div class="panel-full">
        <div class="panel-header">
          <div class="panel-title"><i class="ti ti-chart-line"></i> Daily Flight Volume</div>
          <span class="panel-action">Expand →</span>
        </div>
        <div class="panel-placeholder">
          <i class="ti ti-chart-bar"></i>
          Chart coming soon — connect your data source
        </div>
      </div>

    </div>
  </main>

  <script>
    function updateClock() {
      const now = new Date();
      const h = String(now.getUTCHours()).padStart(2, '0');
      const m = String(now.getUTCMinutes()).padStart(2, '0');
      const s = String(now.getUTCSeconds()).padStart(2, '0');
      document.getElementById('clock').textContent = `UTC ${h}:${m}:${s}`;
    }
    updateClock();
    setInterval(updateClock, 1000);

    document.querySelectorAll('.nav-item').forEach(item => {
      item.addEventListener('click', function(e) {
        e.preventDefault();
        document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
        this.classList.add('active');
      });
    });
  </script>

</body>
</html>
